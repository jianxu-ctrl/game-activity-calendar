# Local development
SERVER_HOST=localhost
SERVER_PORT=3000
CLIENT_DEV_HOST=127.0.0.1
CLIENT_DEV_PORT=5180

# Leave SUDA_DATABASE_URL empty to use the local JSON store.
SUDA_DATABASE_URL=
LOCAL_ACTIVITY_STORE_PATH=data/game-activities.json

# Optional in development. Required in production for upload/sync.
# Open /?admin=1 and enter this token to upload CSV/Excel data.
# On Netlify, set this in Project configuration > Environment variables.
ADMIN_SYNC_TOKEN=

# Optional: enables Event Calendar Preview to import translations from Transify.
# Keep this token server-side only.
TRANSIFY_AUTH_TOKEN=
TRANSIFY_RESOURCE_ID=4115
TRANSIFY_HANDLER_TYPE=json
TRANSIFY_LANGUAGE_IDS=EN:1,CN:5,ES:26,MY:12,ID:6,TH:4,VI:3

# The local defaults below let the platform SDK initialize without a hosted
# platform environment. Production deployments should provide real values.
FORCE_AUTHN_INNERAPI_DOMAIN=http://localhost:3000
FORCE_FRAMEWORK_DISABLE_DATAPASS=true

# Logger
LOG_REQUEST_BODY=true
LOG_RESPONSE_BODY=true
