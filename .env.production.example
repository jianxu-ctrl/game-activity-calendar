# Public origin used by the platform runtime and CSRF checks.
FORCE_AUTHN_INNERAPI_DOMAIN=https://calendar.example.com

# Single Node service. Put HTTPS and the public domain in front with a proxy.
NODE_ENV=production
SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# File-backed production persistence. Mount /data as a persistent volume.
FORCE_FRAMEWORK_DISABLE_DATAPASS=true
LOCAL_ACTIVITY_STORE_PATH=/data/game-activities.json

# Required in production for POST /api/game-activities/sync.
# Public visitors can read the calendar without this token.
ADMIN_SYNC_TOKEN=replace-with-a-long-random-secret

# Optional: required only when importing Preview translations from Transify.
# Keep the token server-side and configure it as a deployment secret.
TRANSIFY_AUTH_TOKEN=replace-with-your-transify-token
TRANSIFY_RESOURCE_ID=4115
TRANSIFY_HANDLER_TYPE=json
TRANSIFY_LANGUAGE_IDS=EN:1,CN:5,ES:26,MY:12,ID:6,TH:4,VI:3

# Optional: use the platform database instead of the JSON file.
# SUDA_DATABASE_URL=postgres://user:password@host:5432/database
